# finance - Environment Variables Configuration
# Copy this file to .env and set the values
# cp .env.example .env

# ===== Required =====
# Anthropic API Key (for Claude Code)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# ===== Optional =====
# FRED API Key (for fetching economic indicator data)
FRED_API_KEY=your_fred_api_key_here

# GitHub Personal Access Token (alternative authentication for gh CLI)
GH_TOKEN=ghp_xxxxxxxxxxxx

# ===== Path Configuration =====
# Custom .env file path (if set, other search strategies are skipped)
# Default: None (searches current directory and parent directories)
# DOTENV_PATH=/path/to/custom/.env

# Data root directory path (used by data_paths package)
# Default: {project_root}/data (relative to pyproject.toml location)
# If set, the directory MUST exist (no fallback — DataPathError is raised)
# DATA_ROOT=/path/to/data

# FRED historical data cache directory
# Default: {DATA_ROOT}/raw/fred/indicators/ (resolved via data_paths.get_path())
# When DATA_ROOT is set, this default changes accordingly.
# Override only if you need a non-standard location.
# FRED_HISTORICAL_CACHE_DIR=/path/to/fred/cache

# FRED series configuration file (URL or local path)
# Default: ./data/config/fred_series.json (relative to current working directory)
# FRED_SERIES_ID_JSON=/path/to/fred_series.json

# ===== Finance News Scraper =====
# NAS output directory for scraped news JSON
# Default: /Volumes/personal_folder/finance-news
# FINANCE_NEWS_NAS_DIR=/Volumes/personal_folder/finance-news

# Local fallback directory when NAS is not mounted
# Default: data/scraped (relative to working directory)
# FINANCE_NEWS_LOCAL_DIR=data/scraped
